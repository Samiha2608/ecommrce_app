<div class="container py-5">
  <div class="row align-items-center">
    <div class="col-md-6 mb-4 mb-md-0">
      <% if @product.images.attached? %>
        <div id="productCarousel" class="carousel slide border rounded shadow-sm" data-bs-ride="carousel">
          <div class="carousel-indicators">
            <% @product.images.each_with_index do |_, idx| %>
              <button type="button"
                      data-bs-target="#productCarousel"
                      data-bs-slide-to="<%= idx %>"
                      class="<%= "active" if idx.zero? %>"
                      aria-current="<%= "true" if idx.zero? %>"
                      aria-label="Slide <%= idx + 1 %>"></button>
            <% end %>
          </div>
          <div class="carousel-inner">
            <% @product.images.each_with_index do |image, idx| %>
              <div class="carousel-item <%= "active" if idx.zero? %>">
                <%= image_tag image, class: "d-block w-100 carousel-img", alt: "Product Image #{idx + 1}" %>
              </div>
            <% end %>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      <% else %>
        <p class="text-muted">No images available for this product.</p>
      <% end %>
    </div>
    <div class="col-md-6">
      <h2 class="mb-3 fw-bold text-capitalize"><%= @product.product_name %></h2>
      <p class="text-muted"><strong>Price:</strong> <%= number_to_currency(@product.price) %></p>
      <p><strong>Description:</strong> <%= @product.description %></p>
      <p><strong>Category:</strong> <%= @product.category %></p>
      <p><strong>Serial Number:</strong> <%= @product.serial_number %></p>
      <p><strong>Stock:</strong> <%= @product.stock %></p>

        <div class="mt-4">
            <% if @product.stock.zero? %>
              <button class="btn btn-secondary" disabled>Out of Stock</button>
            <% elsif @product.user == current_user %>
              <button class="btn btn-secondary" disabled>Your Product</button>
            <% else %>
              <%= button_to "Add to Cart", add_to_cart_product_path(@product), method: :post, class: "btn btn-success" %>
            <% end %>

        </div>
        
      <% if policy(@product).edit? %>
        <div class="mt-3 row gx-2">
          <div class="col-6">
            <%= link_to "Edit", edit_product_path(@product), class: "btn btn-outline-warning w-100" %>
          </div>
          <div class="col-6">
            <%= button_to "Delete", product_path(@product),
                          method: :delete,
                          data: { confirm: "Are you sure?" },
                          form_class: "d-block",
                          class: "btn btn-outline-danger w-100" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
<h3 class="mt-5 fw-bold text-dark">Comments</h3>
<div id="comments_list" class="mt-3">
  <%= render @product.comments %>
</div>
<% unless @product.user == current_user %>
  <turbo-frame id="comment_form" class="mt-4">
    <%= render partial: "comments/form", locals: { comment: @product.comments.build, product: @product } %>
  </turbo-frame>
<% else %>
  <p class="text-muted mt-3">You cannot comment on your own product.</p>
<% end %>







