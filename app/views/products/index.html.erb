<div class="container mt-5">
 <h1 class="text-center mb-4">
  <%= @category.present? ? "#{@category.titleize} Products" : "All Products" %>
</h1>


  <% if flash[:notice] %>
    <div class="alert alert-success text-center"><%= flash[:notice] %></div>
  <% end %>

  <div class="row">
    <% @products.each do |product| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">

          <% if product.images.attached? %>
            <div class="position-relative">
              <%= image_tag product.images.first, class: "card-img-top fixed-image", alt: "Product Image" %>

              <% if product.coupon.present? && product.coupon.discount.present? %>
                <span class="badge bg-danger position-absolute top-0 end-0 m-2 p-2">
                  <%= product.coupon.discount %>% OFF
                </span>
              <% end %>
            </div>
          <% end %>

          <div class="card-body d-flex flex-column justify-content-between">
            <h5 class="card-title"><%= product.product_name %></h5>
            <%= link_to 'Show Product', product_path(product), class: "btn btn-success mt-3 w-100" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .fixed-image {
    height: 200px;
    object-fit: cover;
    width: 100%;
  }
</style>
