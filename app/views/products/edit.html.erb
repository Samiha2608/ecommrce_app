<div class="container mt-5">
  <h2 class="mb-4">Edit Product</h2>

  <%= form_with(model: @product, local: true, html: { multipart: true }) do |f| %>

    <div class="mb-3">
      <%= f.label :product_name, class: "form-label" %>
      <%= f.text_field :product_name, class: "form-control #{'is-invalid' if @product.errors[:product_name].any?}" %>
      <% @product.errors.full_messages_for(:product_name).each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :description, class: "form-label" %>
      <%= f.text_area :description, class: "form-control #{'is-invalid' if @product.errors[:description].any?}", rows: 3 %>
      <% @product.errors.full_messages_for(:description).each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :price, class: "form-label" %>
      <%= f.number_field :price, class: "form-control #{'is-invalid' if @product.errors[:price].any?}", min: 1 %>
      <% @product.errors.full_messages_for(:price).each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :stock, class: "form-label" %>
      <%= f.number_field :stock, class: "form-control #{'is-invalid' if @product.errors[:stock].any?}", min: 1 %>
      <% @product.errors.full_messages_for(:stock).each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :category, class: "form-label" %>
      <%= f.text_field :category, class: "form-control #{'is-invalid' if @product.errors[:category].any?}" %>
      <% @product.errors.full_messages_for(:category).each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :images, "Upload Product Images", class: "form-label" %>
      <%= f.file_field :images, multiple: true, class: "form-control #{'is-invalid' if @product.errors[:images].any?}" %>
      <% @product.errors.full_messages_for(:images).each do |message| %>
        <div class="invalid-feedback d-block"><%= message %></div>
      <% end %>
    </div>

    <%= f.submit "Update Product", class: "btn btn-success" %>
    <%= link_to "Cancel", products_path, class: "btn btn-secondary ms-2" %>
  <% end %>
</div>
