<h2 class="mb-4 text-center">Your Shopping Cart</h2>

<ul class="list-group shadow-sm mb-4">
  <% @cart_items.each do |item| %>
    <% product = item.product %>
    <li class="list-group-item py-3">
      <div class="row align-items-center">

        <div class="col-md-2 text-center">
          <% if product.images.attached? %>
            <%= image_tag(product.images.first, class: "img-thumbnail me-3", size: "100x100") %>
          <% else %>
            <%= image_tag("placeholder.png", class: "img-thumbnail me-3", size: "100x100") %>
          <% end %>
        </div>

        <div class="col-md-4">
          <h5 class="mb-1"><%= product.product_name %></h5>
          <p class="mb-1 text-muted"><%= truncate(product.description, length: 50) %></p>

        </div>

        <div class="col-md-3">
          <%= form_with model: item, url: update_quantity_cart_path(item), method: :patch, data: { turbo_stream: true }, class: "d-flex align-items-center gap-2", local: false do |f| %>
            <%= f.label :quantity, nil, class: "visually-hidden" %>
            <%= f.number_field :quantity, value: item.quantity, min: 0, max: product.stock, class: "form-control form-control-sm", style: "width: 60px;" %>
            <%= f.submit "Update", class: "btn btn-outline-primary btn-sm" %>
          <% end %>
        </div>

          <div class="col-md-3 text-end">
            <% original_price = product.price * item.quantity %>

            <% if session[:applied_coupon_id] && product.coupon_id == session[:applied_coupon_id].to_i %>
              <% original_price = product.price * item.quantity %>
              <% discounted_price = original_price * (1 - product.coupon.discount.to_f / 100) %>
            
              <span class="text-muted text-decoration-line-through"><%= number_to_currency(original_price) %></span><br>
              <strong class="text-success fs-5"><%= number_to_currency(discounted_price) %></strong>
            <% else %>
              <strong class="fs-5"><%= number_to_currency(product.price * item.quantity) %></strong>
            <% end %>


            <%= button_to "Remove", remove_item_cart_path(item), method: :delete,
                data: { turbo_confirm: "Are you sure you want to remove this item?" },
                class: "btn btn-sm btn-outline-danger mt-2" %>
          </div>

      </div>
    </li>
  <% end %>
</ul>

<%= form_with url: apply_coupon_cart_path, method: :post, local: true do |form| %>
  <div class="input-group mt-4 mb-3 w-50 mx-auto">
    <%= form.text_field :coupon_code, class: "form-control", placeholder: "Enter coupon code" %>
    <%= form.submit "Apply Coupon", class: "btn btn-outline-success" %>
  </div>
<% end %>

<% if flash[:coupon_success] %>
  <div class="alert alert-success text-center"><%= flash[:coupon_success] %></div>
<% elsif flash[:coupon_error] %>
  <div class="alert alert-danger text-center"><%= flash[:coupon_error] %></div>
<% end %>


<% if @cart_items.any? %>
  <div class="text-center">
    <%= button_to "Proceed to Checkout", checkouts_path, method: :post, class: "btn btn-success mt-4", data: { turbo: false } %>
  </div>
<% end %>

<div id="cart_status">
  <% if @cart_items.empty? %>
    <div class="alert alert-info text-center">Your cart is currently empty.</div>
  <% end %>
</div>
