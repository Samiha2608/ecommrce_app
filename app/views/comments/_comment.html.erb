<div id="comment_<%= comment.id %>" class="border rounded p-3 mb-3 shadow-sm bg-light">
  <div class="d-flex justify-content-between align-items-start">
    <div>
      <strong><%= comment.user.full_name %></strong>
      <p class="mb-1"><%= comment.content %></p>
    </div>
    
    <% if comment.user == current_user %>
      <div class="ms-3">
        <%= link_to "Edit", edit_product_comment_path(comment.product, comment),
            data: {
              turbo_frame: "comment_form",
              turbo_preload: false,
              turbo_action: "advance"
            },
            class: "btn btn-sm btn-outline-warning me-1" %>
        <%= button_to "Delete", product_comment_path(comment.product, comment),
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            form: { data: { turbo_stream: true } },
            class: "btn btn-sm btn-outline-danger" %>
      </div>
    <% end %>
  </div>
</div>