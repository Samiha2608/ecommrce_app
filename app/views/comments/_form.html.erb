<turbo-frame id="comment_form" class="mt-4">
  <div class="card shadow-sm border-0">
    <div class="card-body bg-white">
      <%= form_with(model: [ product, comment ], data: { turbo_frame: "comment_form" }, class: "mb-0") do |f| %>

        <div class="mb-3">
          <%= f.text_area :content,
                rows: 3,
                class: "form-control #{'is-invalid' if comment.errors[:content].any?}",
                placeholder: "Write a comment..." %>

          <% comment.errors.full_messages_for(:content).each do |message| %>
            <div class="invalid-feedback d-block"><%= message %></div>
          <% end %>
        </div>

        <div class="d-flex justify-content-start align-items-center">
          <%= f.submit(comment.persisted? ? "Update" : "Post", class: "btn btn-primary btn-sm") %>

          <% if comment.persisted? %>
            <%= link_to "Cancel", product_path(product), data: { turbo_frame: "_top" }, class: "btn btn-secondary btn-sm ms-2" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
