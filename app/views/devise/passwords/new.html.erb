<h2>Forgot your password?</h2>

<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% elsif flash[:notice] %>
  <div class="alert alert-success"><%= flash[:notice] %></div>
<% end %>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, data: { turbo: :false } }) do |f| %>
  
  <div class="mb-3 field col-sm-3">
    <%= f.label :email, class: "form-label" %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control #{'is-invalid' if resource.errors[:email].any?}" %>
    <% resource.errors.full_messages_for(:email).each do |message| %>
      <div class="invalid-feedback d-block"><%= message %></div>
    <% end %>
  </div>

  <div class="actions mb-3 col-sm-3">
    <%= f.submit "Send me reset password instructions", class: "btn btn-success" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
